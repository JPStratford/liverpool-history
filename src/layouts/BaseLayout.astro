---
import '../styles/global.css';
const { pageTitle } = Astro.props;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle} | rpool.live</title>
	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Inter:wght@400;500&display=swap" rel="stylesheet" /> 
</head>
  <body>
    <header>
      <nav>
        <a href="/" class="nav-logo">rpool.live</a>
        <button class="nav-toggle" aria-expanded="false" aria-controls="nav-links">
          Menu
        </button>
        <ul id="nav-links" class="nav-links">
          <li><a href="/eras/">Eras</a></li>
          <li><a href="/topics/">Topics</a></li>
          <li><a href="/maps/">Maps</a></li>
          <li><a href="/tours/">Tours</a></li>
          <li><a href="/about/">About</a></li>
        </ul>
      </nav>
    </header>
    <main>
      <slot />
    </main>
<footer>
  <div class="footer-inner">
    <div>
      <p class="footer-brand">rpool.live</p>
      <p class="footer-tagline">Five centuries of the world's most consequential port city.</p>
    </div>
    <div>
      <p class="footer-heading">Explore</p>
      <ul class="footer-links">
        <li><a href="/eras/">Eras</a></li>
        <li><a href="/topics/">Topics</a></li>
        <li><a href="/maps/">Maps</a></li>
        <li><a href="/about/">About</a></li>
      </ul>
    </div>
    <div>
      <p class="footer-heading">Visit</p>
      <ul class="footer-links">
        <li><a href="/tours/">Historical Tours</a></li>
      </ul>
    </div>
  </div>
  <div class="footer-bottom">
    <p>© {new Date().getFullYear()} rpool.live. All rights reserved.</p>
  </div>
</footer>
    <script>
      const toggle = document.querySelector('.nav-toggle');
      const links = document.querySelector('.nav-links');
      toggle?.addEventListener('click', () => {
        const expanded = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', String(!expanded));
        links?.classList.toggle('open');
      });

          const header = document.querySelector('header');
window.addEventListener('scroll', () => {
  if (window.scrollY > 50) {
    header?.classList.add('scrolled');
  } else {
    header?.classList.remove('scrolled');
  }
});
    </script>
  </body>
</html>