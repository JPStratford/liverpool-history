---
interface Props {
  lat: number;
  lng: number;
  zoom?: number;
  caption?: string;
  height?: string;
  inline?: boolean;
  static?: boolean;
  float?: 'left' | 'right';
}

const { 
  lat, 
  lng, 
  zoom = 15, 
  caption, 
  height = '400px',
  inline = false,
  static: isStatic = false,
  float = 'right'
} = Astro.props;

const mapId = `map-${Math.random().toString(36).slice(2, 9)}`;
---

<figure class={`map-figure${inline ? ` map-inline map-float-${float}` : ''}`}>
  {isStatic ? (
    <div class="map-static-wrapper" style={inline ? '' : `height: ${height}`}>
      <img 
        src={`https://tile.openstreetmap.org/${zoom}/${Math.floor((lng + 180) / 360 * Math.pow(2, zoom))}/${Math.floor((1 - Math.log(Math.tan(lat * Math.PI / 180) + 1 / Math.cos(lat * Math.PI / 180)) / Math.PI) / 2 * Math.pow(2, zoom))}.png`}
        alt={caption ?? 'Map location'}
        class="map-static-img"
      />
      <div class="map-attribution">© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors</div>
    </div>
  ) : (
    <div id={mapId} class="map-container" style={`--map-height: ${height}`}></div>
  )}
  {caption && <figcaption class="map-caption">{caption}</figcaption>}
</figure>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script define:vars={{ mapId, lat, lng, zoom }}>
  // @ts-nocheck
  window.__pendingMaps = window.__pendingMaps || [];
  window.__pendingMaps.push({ mapId, lat, lng, zoom });
</script>

<script>
  // @ts-nocheck
  function initMap({ mapId, lat, lng, zoom }) {
    const container = document.getElementById(mapId);
    if (!container || container.__mapInitialised) return;
    container.__mapInitialised = true;

    const map = L.map(container, { scrollWheelZoom: false }).setView([lat, lng], zoom);
    L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
      maxZoom: 19,
    }).addTo(map);

    const icon = L.divIcon({
      html: `<svg viewBox="0 0 38 52" width="38" height="52" xmlns="http://www.w3.org/2000/svg">
        <path d="M19,2 C29,2 36,11 36,19.5 C36,33 19,50 19,50 C19,50 2,33 2,19.5 C2,11 9,2 19,2 Z" fill="#C4956A" stroke="#1C1814" stroke-width="1.5"/>
        <circle cx="19" cy="19.5" r="5.5" fill="#1C1814"/>
      </svg>`,
      className: '',
      iconSize: [38, 52],
      iconAnchor: [19, 52],
    });
    L.marker([lat, lng], { icon }).addTo(map);

    setTimeout(() => {
      map.invalidateSize();
      map._resetView(map.getCenter(), map.getZoom(), true);
      map.eachLayer(layer => {
        if (layer._resetTiles) layer._resetTiles();
      });
    }, 100);

    new ResizeObserver(() => map.invalidateSize()).observe(container);
  }

  function observeMap({ mapId, lat, lng, zoom }) {
    const container = document.getElementById(mapId);
    if (!container) return;

    const observer = new IntersectionObserver((entries, obs) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          obs.disconnect();
          initMap({ mapId, lat, lng, zoom });
        }
      });
    }, { threshold: 0.01 });

    observer.observe(container);
  }

  window.addEventListener('load', () => {
    (window.__pendingMaps || []).forEach(observeMap);
  });
</script>

<style>
  .map-figure {
    margin: 2rem 0;
    border: 1px solid var(--color-border);
    display: block;
    width: 100%;
  }

  .map-inline {
    width: 200px;
    margin-top: 0.25rem;
    margin-bottom: 1rem;
  }

  .map-float-left {
    float: left;
    margin-right: 1.75rem;
  }

  .map-float-right {
    float: right;
    margin-left: 1.75rem;
  }

  .map-container {
    width: 100%;
    height: var(--map-height, 400px);
  }

  .map-inline .map-container {
    height: 200px;
  }

  .map-static-wrapper {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .map-inline .map-static-wrapper {
    height: 200px;
  }

  .map-static-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .map-attribution {
    position: absolute;
    bottom: 0;
    right: 0;
    font-family: 'Inter', sans-serif;
    font-size: 0.65rem;
    background: rgba(255,255,255,0.7);
    padding: 1px 4px;
  }

  .map-attribution a {
    color: inherit;
  }

  .map-caption {
    font-family: 'EB Garamond', serif;
    font-style: italic;
    font-size: var(--text-sm);
    color: var(--color-mersey);
    margin-top: 0.5rem;
    display: block;
  }

  .map-inline .map-caption {
    font-size: 0.75rem;
  }

  :global(.leaflet-container *) {
    box-sizing: content-box;
  }

  :global(.leaflet-container) {
    box-sizing: border-box;
  }
</style>