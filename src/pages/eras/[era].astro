---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import ArticleCard from '../../components/ArticleCard.astro';

export async function getStaticPaths() {
  const eras = await getCollection('eras');
  return eras.map((era: CollectionEntry<'eras'>) => ({
    params: { era: era.data.slug },
    props: { era },
  }));
}

const { era } = Astro.props;

const allArticles = await getCollection('articles');
const eraArticles = allArticles.filter((article: CollectionEntry<'articles'>) => 
  article.data.eras.includes(era.data.slug) && !article.data.draft
);
---

<BaseLayout pageTitle={era.data.name}>
  <div class="page-header">
    <h1>{era.data.name}</h1>
    <p class="subtitle">{era.data.dateRange}</p>
  </div>

  <div class="era-summary">
    <p>{era.data.summary}</p>
  </div>

  {eraArticles.length > 0 ? (
    <div class="era-articles">
      <h2>Articles</h2>
      <div class="article-grid">
        {eraArticles.map((article: CollectionEntry<'articles'>) => (
        <ArticleCard article={article} />
))}
      </div>
    </div>
  ) : (
    <div class="era-empty">
      <p>Articles for this era are coming soon.</p>
    </div>
  )}

</BaseLayout>