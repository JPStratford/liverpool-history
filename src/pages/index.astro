---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import ArticleCard from '../components/ArticleCard.astro';

const allArticles = await getCollection('articles');
const featuredArticles = allArticles.filter((article: CollectionEntry<'articles'>) => 
  !article.data.draft && article.data.featured
);
const recentArticles = allArticles
  .filter((article: CollectionEntry<'articles'>) => !article.data.draft)
  .slice(0, 3);

const eras = await getCollection('eras');
const sortedEras = eras.sort((a: CollectionEntry<'eras'>, b: CollectionEntry<'eras'>) => 
  a.data.order - b.data.order);
---

<BaseLayout pageTitle="Liverpool History" transparentHeader={true}>
<div class="home-hero">
  <div class="home-hero-content">

    <h1 class="home-hero-title" id="hero-title-outer" style="position:relative; display:inline-block;">
      <span id="hero-viewport" style="display:inline-block; overflow:hidden; position:relative; vertical-align:top;">
        <span id="hero-ticker" style="display:inline-block; white-space:nowrap; position:absolute; font-family:inherit; font-size:inherit; font-weight:inherit; letter-spacing:inherit; line-height:inherit; color:inherit;">Liverpool<span id="hero-dot">.</span>live</span>
      </span>
    </h1>

    <p class="home-hero-subtitle">Eight centuries of the world's most consequential port city.</p>
    <a href="/eras/" class="home-hero-cta">Explore the history</a>
  </div>
</div>

  <div class="home-intro container">
    <p>Liverpool's history is one of extraordinary ambition, moral complexity, and fierce civic pride. This site is a growing reference archive — quality-first articles, interactive maps, and original photography exploring the city across five centuries.</p>
  </div>

  <section class="home-eras container">
    <h2 class="section-heading">Explore by Era</h2>
    <div class="eras-grid">
      {sortedEras.map((era: CollectionEntry<'eras'>) => (
        <a href={`/eras/${era.data.slug}`} class="era-card">
        {era.data.heroImage && (
          <div class="era-card-image">
            <Image src={era.data.heroImage.src} alt={era.data.heroImage.alt} width={740} height={400} />
          </div>
        )}
          <div class="era-card-content">
            <p class="era-card-date">{era.data.dateRange}</p>
            <h3 class="era-card-name">{era.data.name}</h3>
            <p class="era-card-description">{era.data.description}</p>
          </div>
        </a>
      ))}
    </div>
  </section>

  {recentArticles.length > 0 && (
    <section class="home-articles container">
      <h2 class="section-heading">Recent Articles</h2>
      <div class="article-grid">
        {recentArticles.map((article: CollectionEntry<'articles'>) => (
          <ArticleCard article={article} />
        ))}
      </div>
    </section>
  )}

  <section class="home-tours container">
    <div class="tours-inner">
      <div class="tours-text">
        <h2 class="section-heading">Historical Walking Tours</h2>
        <p>Explore Liverpool's history in person with a guided walking tour. Each tour is tailored to your interests — from the Georgian merchant quarter to the Victorian waterfront, the stories of emigration, and the city's remarkable modern reinvention.</p>
        <a href="/tours/" class="tours-link">Find out more</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  #hero-dot {
    transition: opacity 0.6s ease;
  }

  #hero-viewport {
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0px,
      black 8px,
      black calc(100% - 8px),
      transparent 100%
    );
    mask-image: linear-gradient(
      to right,
      transparent 0px,
      black 8px,
      black calc(100% - 8px),
      transparent 100%
    );
  }

</style>

<script>
  document.fonts.ready.then(function () {
    const outer    = document.getElementById('hero-title-outer') as HTMLElement;
    const viewport = document.getElementById('hero-viewport') as HTMLElement;
    const ticker   = document.getElementById('hero-ticker') as HTMLElement;
    const dot      = document.getElementById('hero-dot') as HTMLElement;

    if (!outer || !viewport || !ticker || !dot) return;

    const cs = getComputedStyle(outer);
    const measure = document.createElement('span');
    measure.style.cssText = `position:absolute; visibility:hidden; white-space:nowrap; font-family:${cs.fontFamily}; font-size:${cs.fontSize}; font-weight:${cs.fontWeight}; letter-spacing:${cs.letterSpacing}; line-height:${cs.lineHeight};`;

    document.body.appendChild(measure);

    measure.textContent = 'Liverpool';
    const liverpoolWidth = measure.getBoundingClientRect().width;
    const naturalHeight = measure.getBoundingClientRect().height;
    console.log('naturalHeight:', naturalHeight);

    measure.textContent = 'Liver';
    const liverWidth = measure.getBoundingClientRect().width;

    document.body.removeChild(measure);

    const charHeight = ticker.getBoundingClientRect().height;

const viewportWidth = liverpoolWidth + 12;
    viewport.style.width  = viewportWidth + 'px';
    viewport.style.height = (charHeight * 1.2) + 'px';
    outer.style.width     = viewportWidth + 'px';
    outer.style.height    = charHeight + 'px';
    outer.style.overflow  = 'visible';

    ticker.style.left      = `-${liverWidth - 2.2}px`;
    ticker.style.transform = 'translateX(0)';

    setTimeout(() => {
      const duration = 3200;
      const easing   = 'cubic-bezier(0.4, 0, 0.2, 1)';

      ticker.style.transition = `transform ${duration}ms ${easing}`;
      ticker.style.transform  = `translateX(${liverWidth}px)`;

      setTimeout(() => {
        dot.style.opacity = '0';

        // --- SWAP BLOCK START (comment out to disable swap) ---
setTimeout(() => {
          outer.innerHTML = 'Liverpool';
          outer.style.textAlign = 'left';
          outer.style.marginLeft = '4.4px';
          // outer.style.marginLeft = '-7.61px'; this worked visually

        }, 600);
        // --- SWAP BLOCK END ---

      }, duration * 0.78 + 500);

    }, 500);
  });
</script>