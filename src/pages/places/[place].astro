---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import ArticleCard from '../../components/ArticleCard.astro';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  const publishedArticles = articles.filter((article: CollectionEntry<'articles'>) => !article.data.draft);
  
  const allPlaces = [...new Set(publishedArticles.map((article: CollectionEntry<'articles'>) => 
    article.data.places).flat())];
  
  return allPlaces.map((place: string) => {
    const placeArticles = publishedArticles.filter((article: CollectionEntry<'articles'>) => 
      article.data.places.includes(place));
    return {
      params: { place },
      props: { place, articles: placeArticles },
    };
  });
}

const { place, articles } = Astro.props;
---

<BaseLayout pageTitle={place}>
  <div class="page-header">
    <h1>{place}</h1>
    <p class="subtitle">Articles about this place</p>
  </div>

  <div class="article-grid">
    {articles.map((article: CollectionEntry<'articles'>) => (
      <ArticleCard article={article} />
    ))}
  </div>
</BaseLayout>