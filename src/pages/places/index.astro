---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

const allArticles = await getCollection('articles');
const publishedArticles = allArticles.filter((article: CollectionEntry<'articles'>) => !article.data.draft);

const allPlaces = [...new Set(publishedArticles.map((article: CollectionEntry<'articles'>) => 
  article.data.places).flat())].sort();

const mappableArticles = publishedArticles.filter(
  (article: CollectionEntry<'articles'>) =>
    article.data.coordinates?.lat &&
    article.data.coordinates?.lng
);

const pins = mappableArticles.map((article: CollectionEntry<'articles'>) => ({
  lat:        article.data.coordinates!.lat,
  lng:        article.data.coordinates!.lng,
  title:      article.data.title,
  standfirst: article.data.standfirst ?? '',
  eras:       article.data.eras ?? [],
  slug:       article.id,
}));
---

<BaseLayout pageTitle="Places">
  <div class="page-header">
    <h1>Explore by Place</h1>
    <p class="subtitle">Browse articles by location</p>
  </div>

  <div class="topics-intro">
    <p>This site includes places that have a direct bearing on the story of Liverpool. It includes places on both sides of the Mersey, taking in Birkenhead and New Brighton in addition to the city's own boroughs.</p>
  </div>

  <div id="places-map"></div>

  {allPlaces.length > 0 ? (
    <div class="topics-grid">
      {allPlaces.map((place: string) => (
        <a href={`/places/${place}`} class="topic-card">
          <span class="topic-name">{place}</span>
        </a>
      ))}
    </div>
  ) : (
    <div class="topics-empty">
      <p>Places will appear here as articles are published.</p>
    </div>
  )}
</BaseLayout>

<style>
  #places-map {
    width: 100%;
    height: 560px;
    margin-top: 2rem;
    margin-bottom: 3rem;
    border: 1px solid var(--color-border);
    border-radius: 2px;
    z-index: 0;
  }

  @media (max-width: 768px) {
    #places-map {
      height: 380px;
      margin-bottom: 2rem;
    }
  }
</style>

<script define:vars={{ pins }}>
  const link = document.createElement('link');
  link.rel  = 'stylesheet';
  link.href = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.css';
  document.head.appendChild(link);

  const script = document.createElement('script');
  script.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
  script.onload = () => initMap();
  document.head.appendChild(script);

  function initMap() {
    const L = window.L;

    const map = L.map('places-map', {
      center:  [53.4084, -2.9916],
      zoom:    13,
      zoomControl: true,
      scrollWheelZoom: false,
    });

    L.tileLayer('https://{s}.tile.openstreetmap.fr/hot/{z}/{x}/{y}.png', {
      attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
      maxZoom: 19,
    }).addTo(map);

    const pinIcon = L.divIcon({
      html: `<svg viewBox="0 0 38 52" width="38" height="52" xmlns="http://www.w3.org/2000/svg">
        <path d="M19,2 C29,2 36,11 36,19.5 C36,33 19,50 19,50 C19,50 2,33 2,19.5 C2,11 9,2 19,2 Z" fill="#C4956A" stroke="#1C1814" stroke-width="1.5"/>
        <circle cx="19" cy="19.5" r="5.5" fill="#1C1814"/>
      </svg>`,
      className: '',
      iconSize:    [38, 52],
      iconAnchor:  [19, 52],
      popupAnchor: [0, -54],
    });

    const bounds = [];

    pins.forEach(pin => {
      const marker = L.marker([pin.lat, pin.lng], { icon: pinIcon }).addTo(map);

      const eraTagsHtml = pin.eras
        .map(era => `<a href="/eras/${era}" class="tag era-tag map-card-tag">${era}</a>`)
        .join('');

      const popupContent = `
        <div class="map-card">
          <div class="map-card-tags">${eraTagsHtml}</div>
          <h3 class="map-card-title">${pin.title}</h3>
          <p class="map-card-standfirst">${pin.standfirst}</p>
          <a href="/articles/${pin.slug}" class="map-card-link">Read article →</a>
        </div>
      `;

      // Bind popup once at setup time
      marker.bindPopup(L.popup({
        closeButton: true,
        maxWidth: 280,
        className: 'map-popup',
      }).setContent(popupContent));

      let popupOpen = false;

      // Desktop: hover opens popup, click navigates
      marker.on('mouseover', function () {
        if (window.matchMedia('(hover: hover)').matches) {
          marker.openPopup();
          popupOpen = true;
        }
      });

      marker.on('click', function () {
        if (window.matchMedia('(hover: hover)').matches) {
          window.location.href = `/articles/${pin.slug}`;
        } else {
          // Mobile: first tap shows popup, second tap navigates
          if (popupOpen) {
            window.location.href = `/articles/${pin.slug}`;
          } else {
            marker.openPopup();
            popupOpen = true;
          }
        }
      });

      marker.on('popupclose', function () {
        popupOpen = false;
      });

      bounds.push([pin.lat, pin.lng]);
    });

    if (bounds.length > 0) {
      map.fitBounds(bounds, { maxZoom: 15, padding: [40, 40] });
    }
  }
</script>

<style is:global>
  .leaflet-marker-icon:hover {
    filter: brightness(1.15);
  }

  .map-popup .leaflet-popup-content-wrapper {
    background-color: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: 2px;
    box-shadow: 0 4px 20px rgba(28, 24, 20, 0.12);
    padding: 0;
  }

  .map-popup .leaflet-popup-content {
    margin: 0;
    width: 260px !important;
  }

  .map-popup .leaflet-popup-tip {
    background-color: var(--color-background);
  }

  .map-card {
    padding: 1rem 1.25rem;
  }

  .map-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    margin-bottom: 0.5rem;
  }

  .map-card-tag {
    font-size: 0.7rem;
  }

  .map-card-title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 0.4rem 0;
    line-height: 1.3;
  }

  .map-card-standfirst {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: var(--color-mersey);
    line-height: 1.5;
    margin: 0 0 0.75rem 0;
  }

  .map-card-link {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-sandstone);
    border-bottom: 1px solid var(--color-sandstone);
    padding-bottom: 1px;
    transition: color 200ms ease, border-color 200ms ease;
  }

  .map-card-link:hover {
    color: var(--color-text);
    border-color: var(--color-text);
  }

  .map-popup .map-card-tag {
    color: var(--color-background);
  }

  .map-popup .map-card-tag:hover {
    color: var(--color-background);
  }
</style>
